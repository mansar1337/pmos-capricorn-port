f567c9d2b5c64ee312d48d86c8082fb774e6d1a6a4cf1cb2c1b6bd0bd6464da495053be4fff1f56b6b5f7aab56469a21c618a530d277fcb213f0a9b0da1815b0  config-xiaomi-capricorn.aarch64
"
